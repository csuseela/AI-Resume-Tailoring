# ── LLM Provider ──────────────────────────────────────────────
# Options: mock | openai | gemini
LLM_PROVIDER=mock
OPENAI_API_KEY=sk-...          # Get from https://platform.openai.com/api-keys
GEMINI_API_KEY=                # Get from https://aistudio.google.com/app/apikey

# ── Job Source ────────────────────────────────────────────────
# Options: mock | apify | greenhouse | lever | startups | all | apify,greenhouse
JOB_SOURCE_PROVIDER=mock
APIFY_API_TOKEN=               # Get from https://console.apify.com/account#/integrations
APIFY_ACTOR_ID=                # Actor ID e.g. hMvNSpz3JnHgl5jkh
APIFY_RUN_MODE=last_run        # last_run or on_demand
APIFY_SEARCH_LOCATION=United States

# ── Resume Source ─────────────────────────────────────────────
# Options: local | gdrive
RESUME_SOURCE=local
GDRIVE_FILE_ID=                # File ID from your Google Drive share link
GDRIVE_API_KEY=                # Get from https://console.cloud.google.com/apis/credentials

# ── Email Notifications ──────────────────────────────────────
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=                 # Gmail App Password from https://myaccount.google.com/apppasswords
EMAIL_TO=your@email.com

# ── Schedule ──────────────────────────────────────────────────
SCHEDULE_TIMEZONE=America/New_York
